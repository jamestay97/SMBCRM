# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (default LLM provider)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=sk-...

# Ollama (local LLM — set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Internal API (tool-call routes, job worker, server-to-server)
INTERNAL_API_SECRET=generate-a-long-random-string

# Platform super-admin (comma-separated emails allowed to bootstrap /admin)
PLATFORM_ADMIN_EMAILS=you@example.com

# Twilio (optional — for outbound SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Vapi (optional — voice AI)
VAPI_API_KEY=

# Owner deposit alerts (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com

#Admin email
PLATFORM_ADMIN_EMAILS=jamestay97@gmail.com

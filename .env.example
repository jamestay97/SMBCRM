# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL — origin only (no paths). Stripe adds /payment/success automatically.
NEXT_PUBLIC_APP_URL=https://smbcrm.vercel.app
APP_URL=https://smbcrm.vercel.app
WEBHOOK_BASE_URL=https://smbcrm.vercel.app

# OpenAI (default LLM provider — GPT-4o)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=sk-...

# Ollama (local LLM — set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Internal API (tool-call routes, job worker, Vercel cron auth)
INTERNAL_API_SECRET=generate-a-long-random-string
# Optional: Vercel Cron sends Authorization: Bearer CRON_SECRET
CRON_SECRET=generate-a-long-random-string

# Platform super-admin (comma-separated emails allowed to bootstrap /admin)
PLATFORM_ADMIN_EMAILS=you@example.com

# Twilio (SMS — one account, many tenant numbers in admin)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Fallback outbound number if tenant has no assigned number
TWILIO_FROM_NUMBER=

# Vapi (voice AI — optional)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Owner deposit alerts (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com

# Google Maps (lead address autocomplete + embedded map on lead detail)
# Enable Maps JavaScript API + Places API + Maps Embed API in Google Cloud
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
